{
    "name": "phpdot/server-swoole",
    "description": "Swoole HTTP server adapter for PSR-15. Framework-agnostic.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["swoole", "http", "server", "psr-7", "psr-15", "async"],
    "require": {
        "php": ">=8.3",
        "ext-swoole": ">=6.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0",
        "phpdot/contracts": "^1.0",
        "psr/http-server-handler": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "swoole/ide-helper": "*",
        "nyholm/psr7": "^1.8",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Server\\Swoole\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Server\\Swoole\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
